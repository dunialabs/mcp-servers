# Server Configuration
SERVER_NAME=mcp-server-template

# Node Environment
NODE_ENV=development

# OAuth / API token (keep if your server calls external OAuth APIs)
# Updated at runtime via notifications/token/update from PETA Core.
# For local development, paste a valid token here.
# Remove this block if your server does not use token auth.
# accessToken=ya29.your_oauth_token_here

# Add other service-specific configuration here
# API_KEY=your_api_key_here
# DATABASE_URL=postgresql://localhost:5432/mydb
