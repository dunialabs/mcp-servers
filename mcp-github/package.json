{
  "name": "@petaio/mcp-github",
  "version": "1.0.2",
  "description": "GitHub MCP Server - Integrate GitHub repositories, issues, pull requests, and more with Claude through Model Context Protocol",
  "main": "dist/stdio.js",
  "type": "module",
  "bin": {
    "peta-mcp-github": "./dist/stdio.js"
  },
  "scripts": {
    "build": "tsc && npm run build:app",
    "build:app": "node scripts/build-apps.mjs",
    "dev": "tsx watch src/stdio.ts",
    "start": "node dist/stdio.js",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src ui scripts --ext .ts,.mjs",
    "lint:fix": "eslint src ui scripts --ext .ts,.mjs --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepare": "npm run build",
    "docker:build": "./build-docker.sh",
    "docker:build:multi": "./build-docker.sh multi",
    "docker:push": "./build-docker.sh push",
    "docker:clean": "./build-docker.sh clean"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "github",
    "git",
    "repository",
    "issues",
    "pull-requests",
    "peta",
    "typescript",
    "claude",
    "ai",
    "stdio",
    "docker"
  ],
  "author": "PETA Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
